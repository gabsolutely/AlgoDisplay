{
  "name": "algodisplay-test-suite",
  "version": "1.0.0",
  "description": "Test suite for AlgoDisplay algorithm visualizations",
  "main": "javascript/test-runner.js",
  "scripts": {
    "test": "node javascript/test-runner.js",
    "test:js": "node javascript/test-runner.js",
    "test:python": "cd python && python test_runner.py",
